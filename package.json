{
  "name": "@cmc/pi-packages",
  "version": "1.0.0",
  "private": true,
  "description": "Bun-first monorepo for Carter McAlister's Pi packages",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install || true",
    "format": "bunx @biomejs/biome check --write .",
    "lint": "bunx @biomejs/biome check .",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun run --workspaces --if-present test",
    "check": "bun run lint && bun run typecheck && bun run test",
    "check:ci": "bun run check"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-packages",
    "pi-extensions",
    "pi-coding-agent",
    "bun",
    "mise",
    "biome",
    "lefthook"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CarterMcAlister/pi-packages.git"
  },
  "bugs": {
    "url": "https://github.com/CarterMcAlister/pi-packages/issues"
  },
  "homepage": "https://github.com/CarterMcAlister/pi-packages#readme",
  "author": "Carter McAlister",
  "pi": {
    "extensions": []
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@mariozechner/pi-ai": "0.64.0",
    "@mariozechner/pi-coding-agent": "0.64.0",
    "@sinclair/typebox": "0.34.0",
    "@types/node": "22.0.0",
    "bun-types": "latest",
    "lefthook": "^1.11.13",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
