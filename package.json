{
  "name": "@carter-mcalister/pi-packages",
  "version": "1.0.0",
  "private": true,
  "description": "My Pi Packages",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install || true",
    "format": "bunx @biomejs/biome check --write .",
    "lint": "bunx @biomejs/biome check .",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun run --workspaces --if-present test",
    "validate:readme": "node scripts/validate-readme-packages.mjs",
    "check": "bun run lint && bun run typecheck && bun run validate:readme && bun run test",
    "check:ci": "bun run check"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-packages",
    "pi-extensions"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CarterMcAlister/pi-packages.git"
  },
  "bugs": {
    "url": "https://github.com/CarterMcAlister/pi-packages/issues"
  },
  "homepage": "https://github.com/CarterMcAlister/pi-packages#readme",
  "author": "Carter McAlister",
  "pi": {
    "extensions": [
      "./packages/pi-auto-name/src/index.ts",
      "./packages/pi-codex-ask-user/index.ts",
      "./packages/pi-codex-image-gen/src/index.ts",
      "./packages/pi-codex-subagents/src/index.ts",
      "./packages/pi-codex-tasks/src/index.ts",
      "./packages/pi-codex-tools/src/index.ts",
      "./packages/pi-lens/index.ts",
      "./packages/pi-multicodex/index.ts",
      "./packages/pi-powerline-footer/index.ts",
      "./packages/pi-profiles/src/index.ts",
      "./packages/pi-protected-files/src/index.ts",
      "./packages/pi-skillpacks/src/skillpack-session-loader.ts",
      "./packages/pi-worktrunk/src/index.ts",
      "./packages/pi-utils/src/context.ts",
      "./packages/pi-utils/src/files.ts",
      "./packages/pi-utils/src/loop.ts",
      "./packages/pi-utils/src/notify.ts",
      "./packages/pi-utils/src/whimsical.ts",
      "./packages/pi-utils/src/mac-key-display.ts",
      "./packages/pi-utils/src/pi-review-loop/index.ts"
    ],
    "skills": [
      "./packages/pi-codex-ask-user/skills",
      "./packages/pi-lens/skills"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@earendil-works/pi-tui": "0.74.0",
    "@types/node": "22.0.0",
    "bun-types": "latest",
    "lefthook": "2.1.6",
    "typescript": "5.9.3"
  },
  "license": "MIT"
}
