{
  "name": "@carter-mcalister/pi-powerline-footer",
  "version": "0.1.0",
  "description": "Powerline-style status bar extension for Pi",
  "author": "Carter McAlister",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/CarterMcAlister/pi-packages.git",
    "directory": "packages/pi-powerline-footer"
  },
  "bugs": {
    "url": "https://github.com/CarterMcAlister/pi-packages/issues"
  },
  "homepage": "https://github.com/CarterMcAlister/pi-packages/tree/main/packages/pi-powerline-footer#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "*.ts",
    "*.md",
    "*.json",
    "bash-mode/**/*.ts",
    "fixed-editor/**/*.ts"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "powerline",
    "status-bar",
    "extension"
  ],
  "scripts": {
    "format": "bunx @biomejs/biome check --write .",
    "lint": "bunx @biomejs/biome check .",
    "typecheck": "bunx tsc -p ../../tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
