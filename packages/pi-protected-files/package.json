{
  "name": "@carter-mcalister/pi-protected-files",
  "version": "0.1.0",
  "description": "Project-configurable protected file gates for Pi edits",
  "author": "Carter McAlister",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/CarterMcAlister/pi-packages.git",
    "directory": "packages/pi-protected-files"
  },
  "bugs": {
    "url": "https://github.com/CarterMcAlister/pi-packages/issues"
  },
  "homepage": "https://github.com/CarterMcAlister/pi-packages/tree/main/packages/pi-protected-files#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md",
    "tsconfig.json"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "protected-files",
    "permissions"
  ],
  "scripts": {
    "format": "bunx @biomejs/biome check --write .",
    "lint": "bunx @biomejs/biome check .",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
