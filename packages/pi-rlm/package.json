{
  "name": "@carter-mcalister/pi-rlm",
  "version": "0.1.1",
  "description": "RLM-first named workflow extension for Pi Coding Agent",
  "author": "Carter McAlister",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CarterMcAlister/pi-packages.git",
    "directory": "packages/pi-rlm"
  },
  "bugs": {
    "url": "https://github.com/CarterMcAlister/pi-packages/issues"
  },
  "homepage": "https://github.com/CarterMcAlister/pi-packages/tree/main/packages/pi-rlm#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "skills",
    "README.md"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "rlm",
    "workflow",
    "ax-agent"
  ],
  "scripts": {
    "format": "bunx @biomejs/biome check --write .",
    "lint": "bunx @biomejs/biome check .",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "@ax-llm/ax": "^19.0.45",
    "@mariozechner/jiti": "^2.6.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "0.34.0",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
