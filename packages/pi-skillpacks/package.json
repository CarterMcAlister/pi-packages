{
  "name": "@cmc/pi-skillpacks",
  "version": "0.1.0",
  "description": "Session-scoped skill pack loader for Pi",
  "author": "Carter McAlister",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/CarterMcAlister/pi-packages.git",
    "directory": "packages/pi-skillpacks"
  },
  "bugs": {
    "url": "https://github.com/CarterMcAlister/pi-packages/issues"
  },
  "homepage": "https://github.com/CarterMcAlister/pi-packages/tree/main/packages/pi-skillpacks#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "skills",
    "skillpacks"
  ],
  "scripts": {
    "format": "bunx @biomejs/biome check --write .",
    "lint": "bunx @biomejs/biome check .",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "pi": {
    "extensions": [
      "./src/skillpack-session-loader.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
