{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"root": false,
	"extends": ["../../biome.json"],
	"formatter": {
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noExplicitAny": "off",
				"noGlobalIsNan": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	}
}
