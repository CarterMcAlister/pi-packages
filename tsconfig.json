{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": ["bun-types"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["packages/**/*.ts", "scripts/**/*.ts"],
  "exclude": [
    "packages/pi-multicodex/**",
    "packages/pi-codex-ask-user/**",
    "packages/pi-powerline-footer/**",
    "packages/pi-lens/**"
  ]
}
